FROM apache/airflow:2.10.5-python3.11

USER root
WORKDIR /opt/machledata

COPY pyproject.toml README.md ./
COPY src ./src
COPY configs ./configs
COPY scripts ./scripts
COPY workflows ./workflows

RUN pip install --no-cache-dir -e .

ENV PYTHONPATH=/opt/machledata/src:/opt/machledata:/opt/airflow/dags
ENV MACHLEDATA_ARTIFACT_ROOT=/opt/airflow/artifacts

USER airflow
WORKDIR /opt/airflow
