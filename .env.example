# Copy this file to .env and fill in the values.
# .env is gitignored; do not commit it.

# GCP project
GOOGLE_CLOUD_PROJECT=machledata-495608

# Region (must match the bucket and Artifact Registry region)
VERTEX_REGION=europe-west6

# BigQuery dataset (already created with images + labels tables)
BIGQUERY_DATASET=machledata

# GCS paths used by the pipeline
VERTEX_PIPELINE_ROOT=gs://machledata-495608-machledata/pipeline_root
VERTEX_ARTIFACT_ROOT=gs://machledata-495608-machledata/artifacts

# Service account used to run the pipeline on Vertex AI
VERTEX_SERVICE_ACCOUNT=machledata-pipeline@machledata-495608.iam.gserviceaccount.com

# Container image in Artifact Registry
MACHLEDATA_PIPELINE_IMAGE=europe-west6-docker.pkg.dev/machledata-495608/machledata/machledata:latest

# Local default for the FastAPI inference app. Off-the-shelf YOLOv8 nano.
# When deploying a fine-tuned model, point this at the trained .pt path.
MODEL_ARTIFACT_PATH=yolov8n.pt
